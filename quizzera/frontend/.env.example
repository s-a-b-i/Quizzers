# Copy to .env.local (Next.js loads .env.local automatically). Restart dev server after changes.
# Used by next.config.js rewrites only: /api/* on this app is proxied to this URL.
# The browser calls /api/* on the same host as Next (e.g. :3006) — no CORS. Wrong URL → 404 on /api/*.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
