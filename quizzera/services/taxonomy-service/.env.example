PORT=3003
# Base URL of user-service (no /users suffix). Used when no User row exists in quizzera_taxonomy.
USER_SERVICE_URL=http://localhost:3002
# Use the same style of MONGO_URI as your other services for consistency.
# Local (no Atlas): mongodb://localhost:27017/quizzera_taxonomy
# Atlas (recommended if auth/users already use mongodb+srv): encode special chars in the password (e.g. @ → %40)
# MONGO_URI=mongodb+srv://USER:PASSWORD_ENCODED@cluster0.xxxxx.mongodb.net/quizzera_taxonomy?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/quizzera_taxonomy
# Optional locally: if omitted, taxonomy-service reads FIREBASE_* from sibling auth-service/.env (override by setting here).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
