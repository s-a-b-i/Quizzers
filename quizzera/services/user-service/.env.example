PORT=3002
# Local: mongodb://localhost:27017/quizzera_users — or same Atlas host as auth-service with DB name quizzera_users
MONGO_URI=mongodb://localhost:27017/quizzera_users
# Optional locally: if omitted, user-service reads FIREBASE_* from sibling auth-service/.env (override by setting here).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
