PORT=3001
# Local: mongodb://localhost:27017/quizzera_auth
# Atlas: encode special chars in the password (e.g. @ -> %40)
# Atlas URI format pieces:
# - scheme: mongodb+srv://
# - credentials: <username> + : + <url_encoded_password>
# - host/db: @<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_URI=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
JWT_SECRET=
