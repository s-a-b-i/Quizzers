PORT=3004
MONGO_URI=mongodb://localhost:27017/quizzera_mcq
# Same Mongo host/cluster as taxonomy-service; DB name only (used to resolve subjectIds for exam-body filters).
# TAXONOMY_DB_NAME=quizzera_taxonomy
# Used by verifyToken when no User row exists in quizzera_mcq (same pattern as taxonomy-service).
USER_SERVICE_URL=http://localhost:3002
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Shared with exam-service for POST /mcqs/internal/fetch-for-exam (not proxied via gateway).
# Same value in exam-service/.env
INTERNAL_SECRET=quizzera-dev-internal-secret
# Optional: path to taxonomy-ids-for-mcq.json for `npm run seed`. Defaults try ./scripts/taxonomy-ids-for-mcq.json then ../../taxonomy-service/scripts/taxonomy-ids-for-mcq.json (run taxonomy seed first).
# TAXONOMY_IDS_JSON=
